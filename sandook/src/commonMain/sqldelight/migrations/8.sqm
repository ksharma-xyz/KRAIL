-- Migration 8: Add StopLabels table with default Home and Work labels

CREATE TABLE IF NOT EXISTS StopLabels (
    label TEXT NOT NULL PRIMARY KEY,
    emoji TEXT NOT NULL,
    stop_id TEXT,
    stop_name TEXT,
    sort_order INTEGER NOT NULL DEFAULT 0
);

INSERT OR IGNORE INTO StopLabels(label, emoji, stop_id, stop_name, sort_order) VALUES ('Home', '🏠', NULL, NULL, 0);
INSERT OR IGNORE INTO StopLabels(label, emoji, stop_id, stop_name, sort_order) VALUES ('Work', '💼', NULL, NULL, 1);
