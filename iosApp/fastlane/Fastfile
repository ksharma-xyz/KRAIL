# Fastfile for KRAIL iOS App

skip_docs

default_platform(:ios)

platform :ios do
  after_all do |lane|
    cleanup_ci_keychain if is_ci
  end

  error do |lane, exception|
    cleanup_ci_keychain if is_ci
  end

  desc "Build iOS App for Release"
  lane :build_release do
    setup_ci if is_ci

    # Xcode version is selected by maxim-lobanov/setup-xcode in the CI workflow.
    # xcversion is removed — the underlying xcode-install gem is sunsetted and
    # xcversion is broken on macos-15 runners (fastlane/fastlane#29469).

    # Build the app.
    # xcargs forces manual signing during the archive phase — without this, Xcode tries
    # to manage signing automatically and fails in CI where it can't reach Apple servers.
    # export_options.provisioningProfiles covers the export phase.
    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "iosApp.ipa",
      clean: true,
      # xcargs covers the archive phase; export_options.provisioningProfiles covers export.
      # PROVISIONING_PROFILE_SPECIFIER is passed here so xcodebuild knows which profile
      # to use during .xcarchive creation. xcargs apply globally, but in practice only
      # the main app target resolves this profile — SPM resource bundles are unsigned.
      # If SPM targets break again, replace PROVISIONING_PROFILE_SPECIFIER with
      # PROVISIONING_PROFILE_SPECIFIER[sdk=iphoneos*] to scope it to device builds only.
      xcargs: "CODE_SIGN_STYLE=Manual " \
              "CODE_SIGN_IDENTITY='Apple Distribution' " \
              "DEVELOPMENT_TEAM='#{ENV["DEVELOPMENT_TEAM"]}' " \
              "PROVISIONING_PROFILE_SPECIFIER='#{ENV["PROVISIONING_PROFILE_NAME"]}'",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          ENV["APP_BUNDLE_ID"] => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    # Load API key from APP_STORE_CONNECT_API_KEY_* env vars (set in CI workflow) into lane context.
    # upload_to_testflight then picks it up automatically — no api_key_path needed.
    app_store_connect_api_key
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Build and Upload to TestFlight"
  lane :release do
    build_release
    upload_testflight
  end
end

# Deletes the temp keychain created by setup_ci so subsequent runs start clean.
# Without this, a failed run leaves the keychain behind and the next run's
# setup_ci call fails because the keychain already exists.
def cleanup_ci_keychain(name = "fastlane_tmp_keychain")
  if File.exist? File.expand_path("~/Library/Keychains/#{name}-db")
    delete_keychain(name: name)
    sh("security default-keychain -s ~/Library/Keychains/login.keychain-db")
  end
end

